# TryHackMe Testing Configuration
SITE_DOMAIN=10.10.123.45  # Replace with your machine IP

# Port scanning settings
SCAN_ALL_PORTS=true  # Set to true to scan all 65535 ports
START_PORT=1
END_PORT=65535
PORT_SCAN_SPEED=fast  # slow, medium, fast, insane
CONCURRENT_SCANS=500  # Number of concurrent port scans

# Common ports to always check (used if SCAN_ALL_PORTS=false)
COMMON_PORTS=21,22,23,25,53,80,110,111,135,139,143,443,445,993,995,1723,3306,3389,5900,6379,27017,8080,8443,1337,6666,6667,6668,6669,7000,7001,8000,8001,8008,8081,8443,8888,9000,9090,9999

# VPN Settings
THM_VPN_INTERFACE=tun0

# Request Settings
REQUEST_TIMEOUT=9999
MAX_CONCURRENT=9999
VERIFY_SSL=false

# Scan Settings
SCAN_DEPTH=normal  # Options: light, normal, deep
BANNER_GRAB=true  # Try to get service banners

# Performance Settings
MAX_RETRIES=2
CONNECTION_TIMEOUT=2
